{
  "WorkflowName": "MapReduceWordCount",
  "FunctionInvoke": "extract-words",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "extract-words": {
      "FunctionName": "extract_words",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_pdf": "words.pdf",
        "output_file": "words.txt"
      },
      "InvokeNext": [
        "split-dataset"
      ]
    },
    "split-dataset": {
      "FunctionName": "split_dataset",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_file": "words.txt",
        "n_splits": 4,
        "splits_folder": "MapReduce/splits"
      },
      "InvokeNext": [
        "mapper(4)"
      ]
    },
    "mapper": {
      "FunctionName": "mapper",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "splits_folder": "MapReduce/splits",
        "map_folder": "MapReduce/map_out"
      },
      "InvokeNext": [
        "reducer"
      ]
    },
    "reducer": {
      "FunctionName": "reducer",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "map_folder": "MapReduce/map_out",
        "output_folder": "MapReduce/reduce_out",
        "output_file": "word_counts.csv"
      },
      "InvokeNext": [
        "visualize"
      ]
    },
    "visualize": {
      "FunctionName": "visualize",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "reduce_folder": "MapReduce/reduce_out",
        "input_file": "word_counts.csv",
        "output_folder": "MapReduce",
        "output_file": "word_count_plot.png",
        "top_n": 20
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "extract-words": "ghcr.io/faasr/github-actions-python:latest",
    "split-dataset": "ghcr.io/faasr/github-actions-python:latest",
    "mapper": "ghcr.io/faasr/github-actions-python:latest",
    "reducer": "ghcr.io/faasr/github-actions-python:latest",
    "visualize": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "extract_words": "nolcut/FaaSr-workflow-testing/main/functions/extract_words.py",
    "split_dataset": "nolcut/FaaSr-workflow-testing/main/functions/split_dataset.py",
    "mapper": "nolcut/FaaSr-workflow-testing/main/functions/mapper.py",
    "reducer": "nolcut/FaaSr-workflow-testing/main/functions/reducer.py",
    "visualize": "nolcut/FaaSr-workflow-testing/main/functions/visualize.py"
  },
  "PyPIPackageDownloads": {
    "extract-words": [
      "pypdf"
    ],
    "split-dataset": [],
    "mapper": [],
    "reducer": [],
    "visualize": [
      "matplotlib"
    ]
  }
}
