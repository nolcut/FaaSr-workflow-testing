{
  "WorkflowName": "MapReduceWordCount",
  "FunctionInvoke": "generate",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "generate": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "generate_dataset",
      "Arguments": {
        "folder": "MapReduce",
        "output_file": "input.txt",
        "num_words": 5000,
        "words": [
          "cat",
          "dog",
          "bird",
          "horse",
          "pig"
        ],
        "seed": 42
      },
      "InvokeNext": [
        "split"
      ]
    },
    "split": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "split_text",
      "Arguments": {
        "folder": "MapReduce",
        "input_file": "input.txt",
        "num_mappers": 3,
        "chunk_prefix": "chunk"
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "map_count",
      "Arguments": {
        "folder": "MapReduce",
        "chunk_prefix": "chunk",
        "map_out_prefix": "map_out"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "shuffle_flatten",
      "Arguments": {
        "folder": "MapReduce",
        "map_out_prefix": "map_out",
        "num_mappers": 3,
        "shuffle_prefix": "shuffle"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "reduce_count",
      "Arguments": {
        "folder": "MapReduce",
        "shuffle_prefix": "shuffle",
        "reduce_out_prefix": "reduce_out"
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "generate": "ghcr.io/faasr/github-actions-python:latest",
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "generate_dataset": "nolcut/FaaSr-workflow-testing/main/functions/generate_dataset.py",
    "split_text": "nolcut/FaaSr-workflow-testing/main/functions/split_text.py",
    "map_count": "nolcut/FaaSr-workflow-testing/main/functions/map_count.py",
    "shuffle_flatten": "nolcut/FaaSr-workflow-testing/main/functions/shuffle_flatten.py",
    "reduce_count": "nolcut/FaaSr-workflow-testing/main/functions/reduce_count.py"
  }
}
