{
  "WorkflowName": "WordCountMapReduce",
  "FunctionInvoke": "extract-words",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "extract-words": {
      "FunctionName": "extract_words",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_pdf": "words.pdf",
        "output_file": "words.txt"
      },
      "InvokeNext": [
        "split-dataset"
      ]
    },
    "split-dataset": {
      "FunctionName": "split_dataset",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_file": "words.txt",
        "part_prefix": "part",
        "num_parts": 3
      },
      "InvokeNext": [
        "map-words(3)"
      ]
    },
    "map-words": {
      "FunctionName": "map_words",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "part_prefix": "part",
        "map_prefix": "map_out"
      },
      "InvokeNext": [
        "reduce-counts"
      ]
    },
    "reduce-counts": {
      "FunctionName": "reduce_counts",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "map_prefix": "map_out",
        "output_file": "word_counts.csv"
      },
      "InvokeNext": [
        "visualize"
      ]
    },
    "visualize": {
      "FunctionName": "visualize",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_file": "word_counts.csv",
        "output_file": "word_counts.png",
        "top_n": 20
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "extract-words": "ghcr.io/faasr/github-actions-python:latest",
    "split-dataset": "ghcr.io/faasr/github-actions-python:latest",
    "map-words": "ghcr.io/faasr/github-actions-python:latest",
    "reduce-counts": "ghcr.io/faasr/github-actions-python:latest",
    "visualize": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "extract_words": "nolcut/FaaSr-workflow-testing/main/functions/extract_words.py",
    "split_dataset": "nolcut/FaaSr-workflow-testing/main/functions/split_dataset.py",
    "map_words": "nolcut/FaaSr-workflow-testing/main/functions/map_words.py",
    "reduce_counts": "nolcut/FaaSr-workflow-testing/main/functions/reduce_counts.py",
    "visualize": "nolcut/FaaSr-workflow-testing/main/functions/visualize.py"
  },
  "PyPIPackageDownloads": {
    "extract_words": [
      "pypdf"
    ],
    "split_dataset": [],
    "map_words": [],
    "reduce_counts": [],
    "visualize": [
      "matplotlib"
    ]
  }
}
