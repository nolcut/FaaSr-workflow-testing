{
  "WorkflowName": "MapReduceWordCount",
  "FunctionInvoke": "generate",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "generate": {
      "FunctionName": "generate_input",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "output_file": "input.txt",
        "words": [
          "cat",
          "dog",
          "bird",
          "horse",
          "pig"
        ],
        "total_words": 5000,
        "seed": 42
      },
      "InvokeNext": [
        "split"
      ]
    },
    "split": {
      "FunctionName": "mr_split",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_file": "input.txt",
        "n_splits": 3,
        "batch_prefix": "batch_"
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FunctionName": "mr_map",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "batch_prefix": "batch_",
        "map_prefix": "map_"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FunctionName": "mr_shuffle",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "map_prefix": "map_",
        "group_prefix": "group_"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FunctionName": "mr_reduce",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "group_prefix": "group_",
        "result_prefix": "result_"
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "generate": "ghcr.io/faasr/github-actions-python:latest",
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "generate_input": "nolcut/FaaSr-workflow-testing/main/functions/generate_input.py",
    "mr_split": "nolcut/FaaSr-workflow-testing/main/functions/mr_split.py",
    "mr_map": "nolcut/FaaSr-workflow-testing/main/functions/mr_map.py",
    "mr_shuffle": "nolcut/FaaSr-workflow-testing/main/functions/mr_shuffle.py",
    "mr_reduce": "nolcut/FaaSr-workflow-testing/main/functions/mr_reduce.py"
  },
  "PyPIPackageDownloads": {
    "generate_input": [],
    "mr_split": [],
    "mr_map": [],
    "mr_shuffle": [],
    "mr_reduce": []
  }
}
