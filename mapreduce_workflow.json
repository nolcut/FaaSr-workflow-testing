{
  "WorkflowName": "MapReduceWordCount",
  "FunctionInvoke": "generate",
  "DefaultDataStore": "My_S3_Bucket",
  "LoggingDataStore": "My_S3_Bucket",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",

  "ActionList": {
    "generate": {
      "FunctionName": "generate_input",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "output_file": "input.txt",
        "words": ["cat", "dog", "bird", "horse", "pig"],
        "total_words": 5000,
        "seed": 42
      },
      "InvokeNext": ["split"]
    },

    "split": {
      "FunctionName": "mr_split",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "input_file": "input.txt",
        "n_splits": 3,
        "batch_prefix": "batch_"
      },
      "InvokeNext": ["map(3)"]
    },

    "map": {
      "FunctionName": "mr_map",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "batch_prefix": "batch_",
        "map_prefix": "map_"
      },
      "InvokeNext": ["shuffle"]
    },

    "shuffle": {
      "FunctionName": "mr_shuffle",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "map_prefix": "map_",
        "group_prefix": "group_"
      },
      "InvokeNext": ["reduce(5)"]
    },

    "reduce": {
      "FunctionName": "mr_reduce",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "MapReduce",
        "group_prefix": "group_",
        "result_prefix": "result_"
      },
      "InvokeNext": []
    }
  },

  "ComputeServers": {
    "My_GitHub_Account": {
      "FaaSType": "GitHubActions",
      "UserName": "YOUR_GITHUB_USERNAME",
      "ActionRepoName": "MapReduceWordCount",
      "Branch": "main",
      "UseSecretStore": true
    }
  },

  "DataStores": {
    "My_S3_Bucket": {
      "Endpoint": "https://play.min.io",
      "Bucket": "faasr-mapreduce",
      "Region": "us-east-1",
      "Writable": "TRUE"
    }
  },

  "ActionContainers": {
    "generate": "ghcr.io/faasr/github-actions-python:latest",
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest"
  },

  "FunctionGitRepo": {
    "generate_input": "YOUR_GITHUB_USERNAME/MapReduceWordCount/functions",
    "mr_split": "YOUR_GITHUB_USERNAME/MapReduceWordCount/functions",
    "mr_map": "YOUR_GITHUB_USERNAME/MapReduceWordCount/functions",
    "mr_shuffle": "YOUR_GITHUB_USERNAME/MapReduceWordCount/functions",
    "mr_reduce": "YOUR_GITHUB_USERNAME/MapReduceWordCount/functions"
  },

  "PyPIPackageDownloads": {
    "generate_input": [],
    "mr_split": [],
    "mr_map": [],
    "mr_shuffle": [],
    "mr_reduce": []
  }
}
