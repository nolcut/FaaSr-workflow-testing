{
  "WorkflowName": "MapReduce-WordCount",
  "FunctionInvoke": "split",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "split": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "generate_and_split",
      "Arguments": {
        "chunks_folder": "MapReduce/chunks",
        "dataset_folder": "MapReduce/input",
        "dataset_file": "dataset.txt",
        "chunk_prefix": "chunk",
        "num_maps": 3,
        "total_words": 5000,
        "words": [
          "cat",
          "dog",
          "bird",
          "horse",
          "pig"
        ],
        "seed": 42
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "map_count",
      "Arguments": {
        "chunks_folder": "MapReduce/chunks",
        "chunk_prefix": "chunk",
        "map_folder": "MapReduce/map",
        "map_prefix": "map"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "shuffle_flatten",
      "Arguments": {
        "map_folder": "MapReduce/map",
        "map_prefix": "map",
        "group_folder": "MapReduce/shuffle",
        "group_prefix": "group",
        "manifest_file": "manifest.json"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "reduce_count",
      "Arguments": {
        "group_folder": "MapReduce/shuffle",
        "group_prefix": "group",
        "reduce_folder": "MapReduce/reduce",
        "reduce_prefix": "reduce"
      },
      "InvokeNext": [
        "collect"
      ]
    },
    "collect": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "collect_results",
      "Arguments": {
        "reduce_folder": "MapReduce/reduce",
        "reduce_prefix": "reduce",
        "output_folder": "MapReduce/output",
        "result_file": "result.json"
      }
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest",
    "collect": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "generate_and_split": "nolcut/FaaSr-workflow-testing/main/functions/generate_and_split.py",
    "map_count": "nolcut/FaaSr-workflow-testing/main/functions/map_count.py",
    "shuffle_flatten": "nolcut/FaaSr-workflow-testing/main/functions/shuffle_flatten.py",
    "reduce_count": "nolcut/FaaSr-workflow-testing/main/functions/reduce_count.py",
    "collect_results": "nolcut/FaaSr-workflow-testing/main/functions/collect_results.py"
  },
  "PyPIPackageDownloads": {
    "generate_and_split": [],
    "map_count": [],
    "shuffle_flatten": [],
    "reduce_count": [],
    "collect_results": []
  }
}
