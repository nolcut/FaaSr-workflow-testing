{
  "FunctionInvoke": "generate-samples(4)",
  "WorkflowName": "generator-demo",
  "InvocationID": "generator-demo-001",
  "DefaultDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "ActionList": {
    "generate-samples": {
      "FunctionName": "generate_samples",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "x_val": 0.0,
        "label": ""
      },
      "ArgumentGenerator": {
        "x_val": {
          "Name": "linspace",
          "Arguments": { "start": 0.0, "stop": 3.0 }
        },
        "label": {
          "Name": "from_list",
          "Arguments": { "values": ["A", "B", "C", "D"] }
        }
      },
      "InvokeNext": ["collect-results"]
    },
    "collect-results": {
      "FunctionName": "collect_results",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "n_samples": 4
      },
      "InvokeNext": ["plot-results"]
    },
    "plot-results": {
      "FunctionName": "plot_results",
      "FaaSServer": "GH",
      "Type": "Python",
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "generate-samples": "ghcr.io/nolcut/gh-py-generator:generators",
    "collect-results": "ghcr.io/nolcut/gh-py-generator:generators",
    "plot-results": "ghcr.io/nolcut/gh-py-generator:generators"
  },
  "FunctionGitRepo": {
    "generate-samples": "nolcut/FaaSr-workflow-testing",
    "collect-results": "nolcut/FaaSr-workflow-testing",
    "plot-results": "nolcut/FaaSr-workflow-testing"
  },
  "PyPIPackageDownloads": {
    "plot-results": ["matplotlib"]
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "UseSecretStore": true,
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main"
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-generators",
      "Region": "us-east-1",
      "Writable": "TRUE"
    }
  }
}
