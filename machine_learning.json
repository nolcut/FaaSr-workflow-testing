{
  "ActionList": {
    "gen": {
      "Arguments": {
        "folder": "MachineLearning",
        "n_samples": 500,
        "n_features": 1024
      },
      "InvokeNext": [
        "train-svm",
        "train-rf"
      ],
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "gen"
    },
    "train-svm": {
      "Arguments": {
        "folder": "MachineLearning"
      },
      "InvokeNext": [],
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_svm"
    },
    "train-rf": {
      "Arguments": {
        "folder": "MachineLearning"
      },
      "InvokeNext": [],
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_rf"
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "gen": "ghcr.io/faasr/github-actions-python:latest",
    "train-svm": "ghcr.io/faasr/github-actions-python:latest",
    "train-rf": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionInvoke": "gen",
  "DefaultDataStore": "S3",
  "FunctionGitRepo": {
    "gen": "nolcut/FaaSr-workflow-testing/main/functions/gen.py",
    "train_svm": "nolcut/FaaSr-workflow-testing/main/functions/train_svm.py",
    "train_rf": "nolcut/FaaSr-workflow-testing/main/functions/train_rf.py"
  },
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "MachineLearning",
  "WorkflowName": "MachineLearning"
}
