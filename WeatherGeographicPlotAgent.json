{
  "ActionList": {
    "GetData": {
      "Arguments": {
        "folder_name": "WeatherGeographicPlot",
        "state_name": "Oregon",
        "county_name": "Benton"
      },
      "InvokeNext": ["ProcessData"],
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "get_geo_data_and_stations"
    },
    "ProcessData": {
      "Arguments": {
        "folder_name": "WeatherGeographicPlot"
      },
      "InvokeNext": ["PlotData"],
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "process_ghcnd_data"
    },
    "PlotData": {
      "Arguments": {
        "folder_name": "WeatherGeographicPlot",
        "county_name": "Benton"
      },
      "InvokeNext": ["test-agent"],
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "plot_county_weekly_temperature"
    },
    "test-agent": {
      "FaaSServer": "GH",
      "Type": "Agent",
      "Arguments": {
        "prompt": "You are a data science expert. Tell me about the TemperatureHeatmap.png in the WeatherGeographicPlot folder. Specifically, whag does this tell me about the temperature in Benton County. Also, provide context about this region and why this info is relevant. Put your response in a file 'weather_insights.txt' in S3."
      },
      "InvokeNext": [
      ]
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UseSecretStore": true,
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UserName": "nolcut"
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent",
      "Region": "us-east-1",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "GetData": "ghcr.io/nolcut/agent-gh-py:lang",
    "ProcessData": "ghcr.io/nolcut/agent-gh-py:lang",
    "PlotData": "ghcr.io/nolcut/agent-gh-py:lang",
    "test-agent": "ghcr.io/nolcut/agent-gh-py:lang"
  },
  "FunctionInvoke": "GetData",
  "DefaultDataStore": "S3",
  "FunctionGitRepo": {
    "get_geo_data_and_stations": "FaaSr/FaaSr-Functions/WeatherGeographicPlot/python",
    "process_ghcnd_data": "FaaSr/FaaSr-Functions/WeatherGeographicPlot/python",
    "plot_county_weekly_temperature": "FaaSr/FaaSr-Functions/WeatherGeographicPlot/python"
  },
  "PyPIPackageDownloads": {
    "get_geo_data_and_stations": ["geopandas"],
    "process_ghcnd_data": ["geopandas"],
    "plot_county_weekly_temperature": [
      "geopandas",
      "matplotlib",
      "numpy",
      "scipy"
    ]
  },
  "FaaSrLog": "FaaSrLog",
  "LoggingDataStore": "S3",
  "WorkflowName": "WeatherGeographicPlot",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S"
}
