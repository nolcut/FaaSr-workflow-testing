{
  "FunctionInvoke": "ocr-pdf",
  "WorkflowName": "ocr-mapreduce-visualize",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "ocr-pdf": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "ocr_pdf",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "words.pdf",
        "output1": "ocr_text.json"
      },
      "InvokeNext": [
        "split-text"
      ]
    },
    "split-text": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "split_text",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "ocr_text.json",
        "output1": "text_chunk_{rank}.json"
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "map",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "text_chunk_{rank}.json",
        "output1": "map_partial_counts_{rank}.json"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "shuffle",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "map_partial_counts_{rank}.json",
        "output1": "shuffle_word_shard_{rank}.json"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "reduce",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "shuffle_word_shard_{rank}.json",
        "output1": "word_total_{rank}.json"
      },
      "InvokeNext": [
        "visualize-outputs"
      ]
    },
    "visualize-outputs": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "visualize_outputs",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "word_total_{rank}.json",
        "output1": "word_counts_chart.png"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "ocr-pdf": "ghcr.io/faasr/github-actions-python:latest",
    "split-text": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest",
    "visualize-outputs": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "ocr_pdf": "nolcut/FaaSr-workflow-testing/main/functions/ocr_pdf.py",
    "split_text": "nolcut/FaaSr-workflow-testing/main/functions/split_text.py",
    "map": "nolcut/FaaSr-workflow-testing/main/functions/map.py",
    "shuffle": "nolcut/FaaSr-workflow-testing/main/functions/shuffle.py",
    "reduce": "nolcut/FaaSr-workflow-testing/main/functions/reduce.py",
    "visualize_outputs": "nolcut/FaaSr-workflow-testing/main/functions/visualize_outputs.py"
  },
  "PyPIPackageDownloads": {
    "ocr_pdf": [
      "pdf2image",
      "pytesseract",
      "Pillow"
    ],
    "visualize_outputs": [
      "matplotlib"
    ]
  }
}