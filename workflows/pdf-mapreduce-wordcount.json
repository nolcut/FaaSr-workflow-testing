{
  "FunctionInvoke": "transcribe-pdf",
  "WorkflowName": "pdf-mapreduce-wordcount",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "transcribe-pdf": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "transcribe_pdf",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "turing.pdf",
        "output1": "transcription.txt"
      },
      "InvokeNext": [
        "split-transcription"
      ]
    },
    "split-transcription": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "split_transcription",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "transcription.txt",
        "output1": "map_batch_{rank}.json"
      },
      "InvokeNext": [
        "map-transcription(3)"
      ]
    },
    "map-transcription": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "map_transcription",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "map_batch_{rank}.json",
        "output1": "map_counts_{rank}.json"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "shuffle",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "map_counts_{rank}.json",
        "output1": "shuffle_word_{rank}.json"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "reduce",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "shuffle_word_{rank}.json",
        "output1": "reduce_total_{rank}.json"
      },
      "InvokeNext": [
        "visualize-histogram"
      ]
    },
    "visualize-histogram": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "visualize_histogram",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "reduce_total_{rank}.json",
        "output1": "wordcount_histogram.png"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "transcribe-pdf": "ghcr.io/faasr/github-actions-python:latest",
    "split-transcription": "ghcr.io/faasr/github-actions-python:latest",
    "map-transcription": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest",
    "visualize-histogram": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "transcribe_pdf": "nolcut/FaaSr-workflow-testing/main/functions/transcribe_pdf.py",
    "split_transcription": "nolcut/FaaSr-workflow-testing/main/functions/split_transcription.py",
    "map_transcription": "nolcut/FaaSr-workflow-testing/main/functions/map_transcription.py",
    "shuffle": "nolcut/FaaSr-workflow-testing/main/functions/shuffle.py",
    "reduce": "nolcut/FaaSr-workflow-testing/main/functions/reduce.py",
    "visualize_histogram": "nolcut/FaaSr-workflow-testing/main/functions/visualize_histogram.py"
  },
  "PyPIPackageDownloads": {
    "transcribe_pdf": [
      "pypdf"
    ],
    "visualize_histogram": [
      "matplotlib"
    ]
  }
}