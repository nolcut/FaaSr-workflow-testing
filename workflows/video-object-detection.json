{
  "FunctionInvoke": "decode-video",
  "WorkflowName": "video-object-detection",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "decode-video": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "decode_video",
      "Arguments": {
        "folder": "video_detection",
        "input1": "video_small.mp4",
        "output1": "frame_batch_{rank}.json"
      },
      "InvokeNext": [
        "detect-objects(2)"
      ]
    },
    "detect-objects": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "detect_objects",
      "Arguments": {
        "folder": "video_detection",
        "input1": "frame_batch_{rank}.json",
        "input2": "frozen_inference_graph.pb",
        "input3": "faster_rcnn_resnet50_coco_2018_01_28.pbtxt",
        "output1": "detections_{rank}.json"
      },
      "InvokeNext": [
        "accumulate-detections"
      ]
    },
    "accumulate-detections": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "accumulate_detections",
      "Arguments": {
        "folder": "video_detection",
        "input1": "detections_1.json",
        "input2": "detections_2.json",
        "output1": "final_detections.json"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "decode-video": "ghcr.io/faasr/github-actions-python:latest",
    "detect-objects": "ghcr.io/faasr/github-actions-python:latest",
    "accumulate-detections": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "decode_video": "nolcut/FaaSr-workflow-testing/main/functions/decode_video.py",
    "detect_objects": "nolcut/FaaSr-workflow-testing/main/functions/detect_objects.py",
    "accumulate_detections": "nolcut/FaaSr-workflow-testing/main/functions/accumulate_detections.py"
  },
  "PyPIPackageDownloads": {
    "decode_video": [
      "opencv-python-headless",
      "numpy"
    ],
    "detect_objects": [
      "opencv-python-headless",
      "numpy"
    ]
  }
}