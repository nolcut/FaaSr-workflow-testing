{
  "FunctionInvoke": "split",
  "WorkflowName": "mapreduce-word-count",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "split": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "split",
      "Arguments": {
        "folder": "workflow_data",
        "output1": "map_batch_{rank}.json"
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "map",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "map_batch_{rank}.json",
        "output1": "map_counts_{rank}.json"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "shuffle",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "map_counts_{rank}.json",
        "output1": "shuffle_word_{rank}.json"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "reduce",
      "Arguments": {
        "folder": "workflow_data",
        "input1": "shuffle_word_{rank}.json",
        "output1": "reduce_total_{rank}.json"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "split": "nolcut/FaaSr-workflow-testing/main/functions/split.py",
    "map": "nolcut/FaaSr-workflow-testing/main/functions/map.py",
    "shuffle": "nolcut/FaaSr-workflow-testing/main/functions/shuffle.py",
    "reduce": "nolcut/FaaSr-workflow-testing/main/functions/reduce.py"
  }
}