{
  "FunctionInvoke": "generate-input-text",
  "WorkflowName": "mapreduce-word-count",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "generate-input-text": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "generate_input_text",
      "Arguments": {
        "folder": "MapReduce",
        "output1": "input_text.json"
      },
      "InvokeNext": [
        "split"
      ]
    },
    "split": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "split",
      "Arguments": {
        "folder": "MapReduce",
        "input1": "input_text.json",
        "output1": "chunk_{rank}.json"
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "map",
      "Arguments": {
        "folder": "MapReduce",
        "input1": "chunk_{rank}.json",
        "output1": "partial_counts_{rank}.json"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "shuffle",
      "Arguments": {
        "folder": "MapReduce",
        "input1": "partial_counts_{rank}.json",
        "output1": "word_counts_{rank}.json",
        "output2": "rank_word_map.json"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "reduce",
      "Arguments": {
        "folder": "MapReduce",
        "input1": "word_counts_{rank}.json",
        "input2": "rank_word_map.json",
        "output1": "final_count_{rank}.json"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "generate-input-text": "ghcr.io/faasr/github-actions-python:latest",
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "generate_input_text": "nolcut/FaaSr-workflow-testing/main/functions/generate_input_text.py",
    "split": "nolcut/FaaSr-workflow-testing/main/functions/split.py",
    "map": "nolcut/FaaSr-workflow-testing/main/functions/map.py",
    "shuffle": "nolcut/FaaSr-workflow-testing/main/functions/shuffle.py",
    "reduce": "nolcut/FaaSr-workflow-testing/main/functions/reduce.py"
  }
}