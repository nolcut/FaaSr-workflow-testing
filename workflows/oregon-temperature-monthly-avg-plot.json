{
  "FunctionInvoke": "download-temperature-data",
  "WorkflowName": "oregon-temperature-monthly-avg-plot",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "download-temperature-data": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "download_temperature_data",
      "Arguments": {
        "folder": "oregon_temp_jan2026",
        "output1": "oregon_temperature_january_2026.csv"
      },
      "InvokeNext": [
        "compute-monthly-averages"
      ]
    },
    "compute-monthly-averages": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "compute_monthly_averages",
      "Arguments": {
        "folder": "oregon_temp_jan2026",
        "input1": "oregon_temperature_january_2026.csv",
        "output1": "oregon_monthly_avg_temperature.csv"
      },
      "InvokeNext": [
        "plot-monthly-averages"
      ]
    },
    "plot-monthly-averages": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "plot_monthly_averages",
      "Arguments": {
        "folder": "oregon_temp_jan2026",
        "input1": "oregon_monthly_avg_temperature.csv",
        "output1": "oregon_monthly_avg_temperature_plot.png"
      }
    }
  },
  "ActionContainers": {
    "download-temperature-data": "ghcr.io/faasr/github-actions-python:latest",
    "compute-monthly-averages": "ghcr.io/faasr/github-actions-python:latest",
    "plot-monthly-averages": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "download_temperature_data": "nolcut/FaaSr-workflow-testing/main/functions/download_temperature_data.py",
    "compute_monthly_averages": "nolcut/FaaSr-workflow-testing/main/functions/compute_monthly_averages.py",
    "plot_monthly_averages": "nolcut/FaaSr-workflow-testing/main/functions/plot_monthly_averages.py"
  },
  "PyPIPackageDownloads": {
    "download_temperature_data": [
      "requests",
      "pandas"
    ],
    "compute_monthly_averages": [
      "pandas"
    ],
    "plot_monthly_averages": [
      "matplotlib",
      "pandas"
    ]
  }
}