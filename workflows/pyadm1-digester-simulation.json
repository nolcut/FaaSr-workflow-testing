{
  "FunctionInvoke": "convert-flow",
  "WorkflowName": "pyadm1-digester-simulation",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "convert-flow": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "convert_flow",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "digester_influent_raw.csv",
        "input2": "digester_initial.csv",
        "output1": "influent_flow_converted.csv",
        "output2": "digester_initial.csv"
      },
      "InvokeNext": [
        "convert-temp",
        "pyadm1"
      ]
    },
    "convert-temp": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "convert_temp",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "influent_flow_converted.csv",
        "output1": "influent_temp_converted.csv"
      },
      "InvokeNext": [
        "convert-solubles"
      ]
    },
    "convert-solubles": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "convert_solubles",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "influent_temp_converted.csv",
        "output1": "influent_solubles_converted.csv"
      },
      "InvokeNext": [
        "fill-gaps"
      ]
    },
    "fill-gaps": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "fill_gaps",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "influent_solubles_converted.csv",
        "output1": "influent_gaps_filled.csv"
      },
      "InvokeNext": [
        "remove-outliers"
      ]
    },
    "remove-outliers": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "remove_outliers",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "influent_gaps_filled.csv",
        "output1": "digester_influent.csv"
      },
      "InvokeNext": [
        "pyadm1"
      ]
    },
    "pyadm1": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "pyadm1",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "digester_influent.csv",
        "input2": "digester_initial.csv",
        "output1": "dynamic_out.csv"
      },
      "InvokeNext": [
        "visualize-outputs"
      ]
    },
    "visualize-outputs": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "visualize_outputs",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input1": "dynamic_out.csv",
        "output1": "simulation_plots.png"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "convert-flow": "ghcr.io/faasr/github-actions-python:latest",
    "convert-temp": "ghcr.io/faasr/github-actions-python:latest",
    "convert-solubles": "ghcr.io/faasr/github-actions-python:latest",
    "fill-gaps": "ghcr.io/faasr/github-actions-python:latest",
    "remove-outliers": "ghcr.io/faasr/github-actions-python:latest",
    "pyadm1": "ghcr.io/faasr/github-actions-python:latest",
    "visualize-outputs": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "convert_flow": "nolcut/FaaSr-workflow-testing/main/functions/convert_flow.py",
    "convert_temp": "nolcut/FaaSr-workflow-testing/main/functions/convert_temp.py",
    "convert_solubles": "nolcut/FaaSr-workflow-testing/main/functions/convert_solubles.py",
    "fill_gaps": "nolcut/FaaSr-workflow-testing/main/functions/fill_gaps.py",
    "remove_outliers": "nolcut/FaaSr-workflow-testing/main/functions/remove_outliers.py",
    "pyadm1": "nolcut/FaaSr-workflow-testing/main/functions/pyadm1.py",
    "visualize_outputs": "nolcut/FaaSr-workflow-testing/main/functions/visualize_outputs.py"
  },
  "PyPIPackageDownloads": {
    "convert_flow": [
      "pandas"
    ],
    "convert_temp": [
      "pandas"
    ],
    "convert_solubles": [
      "pandas"
    ],
    "fill_gaps": [
      "pandas"
    ],
    "remove_outliers": [
      "pandas",
      "numpy"
    ],
    "pyadm1": [
      "pandas<2.0.0",
      "numpy<2.0.0",
      "scipy<1.11.0",
      "matplotlib<3.8.0"
    ],
    "visualize_outputs": [
      "pandas",
      "matplotlib"
    ]
  }
}