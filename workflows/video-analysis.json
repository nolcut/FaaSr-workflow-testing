{
  "FunctionInvoke": "decode",
  "WorkflowName": "video-analysis",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "decode": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "decode",
      "Arguments": {
        "folder": "video_analysis",
        "input1": "video_small.mp4",
        "input2": "frozen_inference_graph.pb",
        "input3": "faster_rcnn_resnet50_coco_2018_01_28.pbtxt",
        "output1": "batch_{rank}.json"
      },
      "InvokeNext": [
        "detect(2)"
      ]
    },
    "detect": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "detect",
      "Arguments": {
        "folder": "video_analysis",
        "input1": "batch_{rank}.json",
        "input2": "frozen_inference_graph.pb",
        "input3": "faster_rcnn_resnet50_coco_2018_01_28.pbtxt",
        "output1": "detections_{rank}.json"
      },
      "InvokeNext": [
        "accumulate"
      ]
    },
    "accumulate": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "accumulate",
      "Arguments": {
        "folder": "video_analysis",
        "input1": "detections_{rank}.json",
        "output1": "all_detections.json"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "decode": "ghcr.io/faasr/github-actions-python:latest",
    "detect": "ghcr.io/faasr/github-actions-python:latest",
    "accumulate": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "decode": "nolcut/FaaSr-workflow-testing/main/functions/decode.py",
    "detect": "nolcut/FaaSr-workflow-testing/main/functions/detect.py",
    "accumulate": "nolcut/FaaSr-workflow-testing/main/functions/accumulate.py"
  },
  "PyPIPackageDownloads": {
    "decode": [
      "opencv-python-headless",
      "numpy"
    ],
    "detect": [
      "opencv-python",
      "numpy"
    ]
  }
}