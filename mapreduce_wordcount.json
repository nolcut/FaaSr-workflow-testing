{
  "WorkflowName": "MapReduceWordCount",
  "FunctionInvoke": "split",
  "DefaultDataStore": "My_S3_Bucket",
  "LoggingDataStore": "My_S3_Bucket",
  "FaaSrLog": "FaaSrLog",
  "ActionList": {
    "split": {
      "FunctionName": "split_input",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "mapreduce",
        "num_maps": 3,
        "total_words": 5000,
        "vocabulary": [
          "cat",
          "dog",
          "bird",
          "horse",
          "pig"
        ],
        "chunk_prefix": "chunk",
        "seed": 42
      },
      "InvokeNext": [
        "map(3)"
      ]
    },
    "map": {
      "FunctionName": "map_word_count",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "mapreduce",
        "chunk_prefix": "chunk",
        "map_prefix": "map_out"
      },
      "InvokeNext": [
        "shuffle"
      ]
    },
    "shuffle": {
      "FunctionName": "shuffle_words",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "mapreduce",
        "map_prefix": "map_out",
        "num_maps": 3,
        "num_reducers": 5,
        "reduce_prefix": "reduce_in"
      },
      "InvokeNext": [
        "reduce(5)"
      ]
    },
    "reduce": {
      "FunctionName": "reduce_word_count",
      "FaaSServer": "My_GitHub_Account",
      "Type": "Python",
      "Arguments": {
        "folder": "mapreduce",
        "reduce_prefix": "reduce_in",
        "result_prefix": "reduce_out"
      }
    }
  },
  "ComputeServers": {
    "My_GitHub_Account": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "My_S3_Bucket": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "split": "ghcr.io/faasr/github-actions-python:latest",
    "map": "ghcr.io/faasr/github-actions-python:latest",
    "shuffle": "ghcr.io/faasr/github-actions-python:latest",
    "reduce": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "split_input": "nolcut/FaaSr-workflow-testing/main/functions/split_input.py",
    "map_word_count": "nolcut/FaaSr-workflow-testing/main/functions/map_word_count.py",
    "shuffle_words": "nolcut/FaaSr-workflow-testing/main/functions/shuffle_words.py",
    "reduce_word_count": "nolcut/FaaSr-workflow-testing/main/functions/reduce_word_count.py"
  },
  "PyPIPackageDownloads": {
    "split_input": [],
    "map_word_count": [],
    "shuffle_words": [],
    "reduce_word_count": []
  }
}
