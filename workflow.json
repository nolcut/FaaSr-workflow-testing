{
  "FunctionInvoke": "gen",
  "WorkflowName": "machine-learning-training-pipeline",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationIDFromDate": "%Y-%m-%d-%H-%M-%S",
  "ActionList": {
    "gen": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "gen",
      "Arguments": {
        "folder": "MachineLearning",
        "n_samples": 500,
        "n_features": 1024,
        "output1": "preprocessed_data.json"
      },
      "InvokeNext": [
        "train-svm",
        "train-random-forest"
      ]
    },
    "train-svm": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_svm",
      "Arguments": {
        "folder": "MachineLearning",
        "input1": "preprocessed_data.json",
        "output1": "svm_accuracy.json"
      },
      "InvokeNext": []
    },
    "train-random-forest": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_random_forest",
      "Arguments": {
        "folder": "MachineLearning",
        "input1": "preprocessed_data.json",
        "output1": "random_forest_accuracy.json"
      },
      "InvokeNext": []
    }
  },
  "ActionContainers": {
    "gen": "ghcr.io/faasr/github-actions-python:latest",
    "train-svm": "ghcr.io/faasr/github-actions-python:latest",
    "train-random-forest": "ghcr.io/faasr/github-actions-python:latest"
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "FunctionGitRepo": {
    "gen": "nolcut/FaaSr-workflow-testing/main/functions/gen.py",
    "train_svm": "nolcut/FaaSr-workflow-testing/main/functions/train_svm.py",
    "train_random_forest": "nolcut/FaaSr-workflow-testing/main/functions/train_random_forest.py"
  },
  "PyPIPackageDownloads": {
    "gen": [
      "scikit-learn",
      "numpy"
    ],
    "train_svm": [
      "scikit-learn",
      "numpy"
    ],
    "train_random_forest": [
      "scikit-learn",
      "numpy"
    ]
  }
}
