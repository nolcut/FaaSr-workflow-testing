{
  "WorkflowName": "MachineLearning",
  "FunctionInvoke": "gen",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "gen": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "gen",
      "Arguments": {
        "N": 500,
        "M": 1024,
        "folder": "ml"
      },
      "InvokeNext": [
        "svm",
        "rf"
      ]
    },
    "svm": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_svm",
      "Arguments": {
        "folder": "ml"
      },
      "InvokeNext": []
    },
    "rf": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_rf",
      "Arguments": {
        "folder": "ml"
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "gen": "ghcr.io/faasr/github-actions-python:latest",
    "svm": "ghcr.io/faasr/github-actions-python:latest",
    "rf": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "gen": "nolcut/FaaSr-workflow-testing/main/functions/gen.py",
    "train_svm": "nolcut/FaaSr-workflow-testing/main/functions/train_svm.py",
    "train_rf": "nolcut/FaaSr-workflow-testing/main/functions/train_rf.py"
  },
  "PyPIPackageDownloads": {
    "gen": [
      "scikit-learn",
      "numpy"
    ],
    "train_svm": [
      "scikit-learn",
      "numpy"
    ],
    "train_rf": [
      "scikit-learn",
      "numpy"
    ]
  }
}
