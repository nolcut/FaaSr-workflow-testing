{
  "WorkflowName": "MachineLearning",
  "FunctionInvoke": "gen",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",

  "ActionList": {
    "gen": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "gen",
      "Arguments": {
        "N": 500,
        "M": 1024,
        "folder": "ml"
      },
      "InvokeNext": [
        "svm",
        "rf"
      ]
    },
    "svm": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_svm",
      "Arguments": {
        "folder": "ml"
      },
      "InvokeNext": []
    },
    "rf": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "train_rf",
      "Arguments": {
        "folder": "ml"
      },
      "InvokeNext": []
    }
  },

  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "<GITHUB_USERNAME>",
      "UseSecretStore": true,
      "ActionRepoName": "<ACTION_REPO_NAME>",
      "Branch": "main"
    }
  },

  "DataStores": {
    "S3": {
      "Endpoint": "<S3_ENDPOINT>",
      "Bucket": "<S3_BUCKET>",
      "Region": "<S3_REGION>"
    }
  },

  "ActionContainers": {
    "gen": "ghcr.io/faasr/github-actions-python:latest",
    "svm": "ghcr.io/faasr/github-actions-python:latest",
    "rf": "ghcr.io/faasr/github-actions-python:latest"
  },

  "FunctionGitRepo": {
    "gen": "<ORG>/<REPO>/<PATH>",
    "train_svm": "<ORG>/<REPO>/<PATH>",
    "train_rf": "<ORG>/<REPO>/<PATH>"
  },

  "PyPIPackageDownloads": {
    "gen": [
      "scikit-learn",
      "numpy"
    ],
    "svm": [
      "scikit-learn",
      "numpy"
    ],
    "rf": [
      "scikit-learn",
      "numpy"
    ]
  }
}
