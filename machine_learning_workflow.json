{
  "WorkflowName": "MachineLearning",
  "FunctionInvoke": "gen",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "gen": {
      "FunctionName": "gen",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "N": 500,
        "M": 1024
      },
      "InvokeNext": [
        "svm",
        "random-forest"
      ]
    },
    "svm": {
      "FunctionName": "svm",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {},
      "InvokeNext": []
    },
    "random-forest": {
      "FunctionName": "random_forest",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {},
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "gen": "ghcr.io/faasr/github-actions-python:latest",
    "svm": "ghcr.io/faasr/github-actions-python:latest",
    "random-forest": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "gen": "nolcut/FaaSr-workflow-testing/main/functions/gen.py",
    "svm": "nolcut/FaaSr-workflow-testing/main/functions/svm.py",
    "random_forest": "nolcut/FaaSr-workflow-testing/main/functions/random_forest.py"
  },
  "PyPIPackageDownloads": {
    "gen": [
      "numpy",
      "scikit-learn"
    ],
    "svm": [
      "numpy",
      "scikit-learn"
    ],
    "random_forest": [
      "numpy",
      "scikit-learn"
    ]
  }
}
