{
  "WorkflowName": "MachineLearning",
  "FunctionInvoke": "gen",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",

  "ActionList": {
    "gen": {
      "FunctionName": "gen",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "N": 500,
        "M": 1024
      },
      "InvokeNext": [
        "svm",
        "random-forest"
      ]
    },
    "svm": {
      "FunctionName": "svm",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {},
      "InvokeNext": []
    },
    "random-forest": {
      "FunctionName": "random_forest",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {},
      "InvokeNext": []
    }
  },

  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "<GITHUB_USERNAME>",
      "ActionRepoName": "<ACTION_REPO_NAME>",
      "Branch": "main",
      "UseSecretStore": true
    }
  },

  "DataStores": {
    "S3": {
      "Endpoint": "<S3_ENDPOINT>",
      "Bucket": "<S3_BUCKET>",
      "Region": "<S3_REGION>"
    }
  },

  "ActionContainers": {
    "gen": "ghcr.io/faasr/github-actions-python:latest",
    "svm": "ghcr.io/faasr/github-actions-python:latest",
    "random-forest": "ghcr.io/faasr/github-actions-python:latest"
  },

  "FunctionGitRepo": {
    "gen": "<ORG>/<REPO>/<PATH>",
    "svm": "<ORG>/<REPO>/<PATH>",
    "random_forest": "<ORG>/<REPO>/<PATH>"
  },

  "PyPIPackageDownloads": {
    "gen": ["numpy", "scikit-learn"],
    "svm": ["numpy", "scikit-learn"],
    "random_forest": ["numpy", "scikit-learn"]
  }
}
