{
  "WorkflowName": "PyADM1Workflow",
  "FunctionInvoke": "validate",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "InvocationID": "",
  "ActionList": {
    "validate": {
      "FunctionName": "validate_inputs",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "pyadm1",
        "influent_file": "digester_influent.csv",
        "initial_file": "digester_initial.csv"
      },
      "InvokeNext": [
        "simulate"
      ]
    },
    "simulate": {
      "FunctionName": "run_pyadm1",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "pyadm1",
        "influent_file": "digester_influent.csv",
        "initial_file": "digester_initial.csv",
        "output_file": "dynamic_out.csv"
      },
      "InvokeNext": [
        "visualize"
      ]
    },
    "visualize": {
      "FunctionName": "visualize_adm1",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "folder": "pyadm1",
        "results_file": "dynamic_out.csv",
        "output_file": "adm1_dashboard.png"
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "validate": "ghcr.io/faasr/github-actions-python:latest",
    "simulate": "ghcr.io/faasr/github-actions-python:latest",
    "visualize": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "validate_inputs": "nolcut/FaaSr-workflow-testing/main/functions/validate_inputs.py",
    "run_pyadm1": "nolcut/FaaSr-workflow-testing/main/functions/run_pyadm1.py",
    "visualize_adm1": "nolcut/FaaSr-workflow-testing/main/functions/visualize_adm1.py"
  },
  "PyPIPackageDownloads": {
    "validate_inputs": [
      "pandas"
    ],
    "run_pyadm1": [
      "numpy",
      "scipy",
      "pandas"
    ],
    "visualize_adm1": [
      "pandas",
      "matplotlib"
    ]
  }
}
