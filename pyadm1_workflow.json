{
  "WorkflowName": "PyADM1CleaningAndSimulation",
  "FunctionInvoke": "convert-units",
  "InvocationID": "",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "FaaSrLog": "FaaSrLog",
  "ActionList": {
    "convert-units": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "convert_units",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input_file": "digester_influent_raw.csv",
        "output_file": "influent_units_converted.csv"
      },
      "InvokeNext": [
        "fill-gaps"
      ]
    },
    "fill-gaps": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "fill_gaps",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input_file": "influent_units_converted.csv",
        "output_file": "influent_filled.csv"
      },
      "InvokeNext": [
        "remove-spikes"
      ]
    },
    "remove-spikes": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "remove_spikes",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input_file": "influent_filled.csv",
        "output_file": "influent_despiked.csv",
        "window": 7,
        "n_sigmas": 3.0
      },
      "InvokeNext": [
        "interpolate"
      ]
    },
    "interpolate": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "interpolate",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input_file": "influent_despiked.csv",
        "output_file": "digester_influent.csv"
      },
      "InvokeNext": [
        "validate"
      ]
    },
    "validate": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "validate",
      "Arguments": {
        "folder": "PyADM1-orig",
        "influent_file": "digester_influent.csv",
        "initial_file": "digester_initial.csv",
        "report_file": "validation_report.csv"
      },
      "InvokeNext": [
        "pyadm1"
      ]
    },
    "pyadm1": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "run_pyadm1",
      "Arguments": {
        "folder": "PyADM1-orig",
        "influent_file": "digester_influent.csv",
        "initial_file": "digester_initial.csv",
        "output_file": "dynamic_out.csv"
      },
      "InvokeNext": [
        "visualize"
      ]
    },
    "visualize": {
      "FaaSServer": "GH",
      "Type": "Python",
      "FunctionName": "visualize",
      "Arguments": {
        "folder": "PyADM1-orig",
        "input_file": "dynamic_out.csv",
        "output_file": "simulation_plots.png"
      },
      "InvokeNext": []
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "convert-units": "ghcr.io/faasr/github-actions-python:latest",
    "fill-gaps": "ghcr.io/faasr/github-actions-python:latest",
    "remove-spikes": "ghcr.io/faasr/github-actions-python:latest",
    "interpolate": "ghcr.io/faasr/github-actions-python:latest",
    "validate": "ghcr.io/faasr/github-actions-python:latest",
    "pyadm1": "ghcr.io/faasr/github-actions-python:latest",
    "visualize": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "convert_units": "nolcut/FaaSr-workflow-testing/main/functions/convert_units.py",
    "fill_gaps": "nolcut/FaaSr-workflow-testing/main/functions/fill_gaps.py",
    "remove_spikes": "nolcut/FaaSr-workflow-testing/main/functions/remove_spikes.py",
    "interpolate": "nolcut/FaaSr-workflow-testing/main/functions/interpolate.py",
    "validate": "nolcut/FaaSr-workflow-testing/main/functions/validate.py",
    "run_pyadm1": "nolcut/FaaSr-workflow-testing/main/functions/run_pyadm1.py",
    "visualize": "nolcut/FaaSr-workflow-testing/main/functions/visualize.py"
  },
  "PyPIPackageDownloads": {
    "convert_units": [
      "pandas"
    ],
    "fill_gaps": [
      "pandas"
    ],
    "remove_spikes": [
      "pandas",
      "numpy"
    ],
    "interpolate": [
      "pandas"
    ],
    "validate": [
      "pandas",
      "numpy"
    ],
    "run_pyadm1": [
      "pandas",
      "numpy",
      "scipy",
      "matplotlib"
    ],
    "visualize": [
      "pandas",
      "matplotlib"
    ]
  }
}
