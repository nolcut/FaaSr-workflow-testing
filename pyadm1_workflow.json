{
  "WorkflowName": "PyADM1Pipeline",
  "FunctionInvoke": "validate",
  "InvocationID": "",
  "FaaSrLog": "FaaSrLog",
  "DefaultDataStore": "S3",
  "LoggingDataStore": "S3",
  "ActionList": {
    "validate": {
      "FunctionName": "validate_inputs",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "input_folder": "pyadm1-inputs",
        "influent_file": "digester_influent.csv",
        "initial_file": "digester_initial.csv"
      },
      "InvokeNext": [
        "simulate"
      ]
    },
    "simulate": {
      "FunctionName": "run_pyadm1",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "validated_folder": "pyadm1-validated",
        "output_folder": "pyadm1-outputs",
        "influent_file": "digester_influent.csv",
        "initial_file": "digester_initial.csv",
        "output_file": "dynamic_out.csv"
      },
      "InvokeNext": [
        "visualize"
      ]
    },
    "visualize": {
      "FunctionName": "visualize_outputs",
      "FaaSServer": "GH",
      "Type": "Python",
      "Arguments": {
        "output_folder": "pyadm1-outputs",
        "validated_folder": "pyadm1-validated",
        "output_file": "dynamic_out.csv",
        "influent_file": "digester_influent.csv",
        "plot_file": "pyadm1_results.png"
      }
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UserName": "nolcut",
      "ActionRepoName": "FaaSr-workflow-testing",
      "Branch": "main",
      "UseSecretStore": true
    }
  },
  "DataStores": {
    "S3": {
      "Endpoint": "https://s3.us-east-1.amazonaws.com",
      "Bucket": "faasr-agent-new",
      "Region": "us-east-1",
      "AccessKey": "S3_AccessKey",
      "SecretKey": "S3_SecretKey",
      "Writable": "TRUE"
    }
  },
  "ActionContainers": {
    "validate": "ghcr.io/faasr/github-actions-python:latest",
    "simulate": "ghcr.io/faasr/github-actions-python:latest",
    "visualize": "ghcr.io/faasr/github-actions-python:latest"
  },
  "FunctionGitRepo": {
    "validate_inputs": "nolcut/FaaSr-workflow-testing/main/functions/validate_inputs.py",
    "run_pyadm1": "nolcut/FaaSr-workflow-testing/main/functions/run_pyadm1.py",
    "visualize_outputs": "nolcut/FaaSr-workflow-testing/main/functions/visualize_outputs.py"
  },
  "PyPIPackageDownloads": {
    "validate_inputs": [
      "pandas==1.5.3",
      "numpy==1.24.4"
    ],
    "run_pyadm1": [
      "pandas==1.5.3",
      "numpy==1.24.4",
      "scipy==1.10.1",
      "matplotlib==3.7.5"
    ],
    "visualize_outputs": [
      "pandas==1.5.3",
      "numpy==1.24.4",
      "matplotlib==3.7.5"
    ]
  }
}
